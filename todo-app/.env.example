# Copy this file to .env and edit the values as needed.
# All values shown here are the defaults used when the key is absent.

# ---- Application ----
APP_NAME="Todo API"
APP_VERSION="1.0.0"
ENVIRONMENT=development      # development | staging | production

# ---- Server ----
HOST=0.0.0.0
PORT=8000
WORKERS=1
DEBUG=false

# ---- Logging ----
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_TO_FILE=true             # write rotating log files under logs/

# ---- Pagination ----
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
